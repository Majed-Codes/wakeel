# Anthropic API Key (primary LLM — Claude)
ANTHROPIC_API_KEY=your-anthropic-key

# Google Cloud (primary transcription — Speech-to-Text)
GOOGLE_CLOUD_PROJECT_ID=your-project-id
GOOGLE_CLOUD_LOCATION=global

# OpenAI API Key (legacy fallback for Whisper + GPT-4)
OPENAI_API_KEY=sk-your-openai-key

# Database URL (PostgreSQL for production, SQLite for dev)
DATABASE_URL=sqlite:///./wakeel.db

# JWT Secret Key
JWT_SECRET_KEY=change-this-to-a-random-secret-key
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=1440

# App Settings
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ChromaDB persist directory
CHROMA_PERSIST_DIR=./chroma_db
